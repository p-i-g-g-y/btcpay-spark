@using BTCPayServer.Models.StoreViewModels
@model BTCPayServer.Models.StoreViewModels.LightningNodeViewModel

@{
    var storeId = Model.StoreId;
    var enableUrl = Url.Action("EnableLightning", "Spark", new { storeId });
    var isSelected = Model.LightningNodeType is LightningNodeType.Custom
                     && Model.ConnectionString?.StartsWith("type=spark", StringComparison.InvariantCultureIgnoreCase) is true;
}

@*
    "Use Spark" pill on BTCPay's Lightning-node setup tab.

    The endpoint is POST (CSRF-protected) since flipping the store's Lightning routing is a
    state change. The radio cannot directly submit a form (it's a radio input, not a button)
    and we can't render a nested <form> here — the surrounding LightningNode-setup view
    already wraps us in its own <form>, and HTML forbids form nesting (the browser would
    silently break our inner form). So the click handler:
      1. Reads the anti-forgery token from whatever form is hosting this view component.
      2. Builds a one-shot form at document.body (outside any other form).
      3. Submits it — browser POSTs and navigates to our redirect response.
    The radio's own click behaviour is left intact (no preventDefault) so it visually checks
    in the same tick we submit.
*@

<input asp-for="LightningNodeType" value="LightningNodeType-Spark" type="radio" id="LightningNodeType-Spark" data-bs-toggle="pill"
       data-bs-target="#CustomSetup" role="tab" aria-controls="SparkSetup"
       aria-selected="@(isSelected ? "true" : "false")"
       class="@(Model.LightningNodeType == LightningNodeType.Custom ? "active" : "")">
<label asp-for="LightningNodeType" for="@($"LightningNodeType-Spark")" text-translate="true">Use Spark</label>

<script>
    (function () {
        var triggerEl = document.getElementById('LightningNodeType-Spark');
        if (!triggerEl) return;

        triggerEl.addEventListener('click', function () {
            // Borrow the host page's antiforgery token (BTCPay's outer Lightning-node form
            // already has one — same token works for any same-origin POST on this page).
            var tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
            var token = tokenInput ? tokenInput.value : '';

            // Construct a one-shot POST form NOT nested inside the outer LightningNode form.
            // Attaching to <body> avoids the HTML5 "no nested forms" parser rule that was
            // silently breaking the previous in-place form.
            var form = document.createElement('form');
            form.method = 'POST';
            form.action = @Html.Raw(Json.Serialize(enableUrl));
            form.style.display = 'none';
            if (token) {
                var t = document.createElement('input');
                t.type = 'hidden';
                t.name = '__RequestVerificationToken';
                t.value = token;
                form.appendChild(t);
            }
            document.body.appendChild(form);
            form.submit();
        });

        if (@(isSelected ? "true" : "false")) {
            // Deactivate currently active tab and activate this tab — matches Arkade's
            // initial-state recovery when Spark is already the configured backend.
            var activeEl = document.querySelector('input[name="LightningNodeType"]:checked');
            if (activeEl && triggerEl) {
                activeEl.removeAttribute('checked');
                activeEl.setAttribute('aria-selected', 'false');
                var activePane = document.querySelector('#LightningNodeTypeTabs .tab-pane.active');
                if (activePane) activePane.classList.remove('active', 'show');
                triggerEl.setAttribute('checked', 'checked');
                triggerEl.setAttribute('aria-selected', 'true');
            }
        }
    })();
</script>
