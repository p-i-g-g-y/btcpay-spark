@model SparkDashboardWidgetViewModel
@*
    Compact Spark widget for the store dashboard. One widget = balance + actions + most recent
    activity row. Designed to sit alongside BTCPay's stock widgets without doubling up. The
    second-slot widget (SparkActivityDashboardWidget) is intentionally a no-op now — we render
    everything here so the dashboard stays calm.
*@
@if (!Model.Configured)
{
    return;
}
@{
    var lockedSats = Model.Balances is null
        ? 0
        : Math.Max(0, Model.Balances.OwnedSats - Model.Balances.AvailableSats);
    var hasActivity = Model.RecentActivity.Count > 0;
}
<div class="widget store-wallet-balance spark-widget" data-testid="spark-dashboard-widget">
    @* Mirrors BTCPay's stock store-wallet-balance idiom: h3 title in <header> with a "View"
       link. Gives the widget the same visual weight as Arkade / on-chain wallets. *@
    <header>
        <h3 class="mb-0" text-translate="true">Spark Wallet</h3>
        <a asp-controller="Spark" asp-action="StoreOverview" asp-route-storeId="@Model.StoreId" text-translate="true">View</a>
    </header>

    <div class="widget-body">
        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="alert alert-warning small mb-0">@Model.Error</div>
        }
        else if (Model.Balances is null)
        {
            <p class="text-secondary small mb-0">No balance available.</p>
        }
        else
        {
            <div class="balance">
                <div class="d-flex align-items-baseline gap-2 flex-wrap">
                    <h3 class="d-inline-block mb-0" data-sensitive>@SparkAmountConverter.FormatSats(Model.Balances.AvailableSats)</h3>
                    <span class="text-secondary fw-semibold text-nowrap">sats available</span>
                </div>
                <div class="text-secondary small mt-1">@SparkAmountConverter.FormatBtc(Model.Balances.AvailableSats) BTC</div>
                @if (lockedSats > 0 || Model.Balances.IncomingSats > 0)
                {
                    <div class="d-flex flex-wrap gap-3 mt-2 small">
                        @if (lockedSats > 0)
                        {
                            <span class="text-secondary"><span class="fw-semibold">@SparkAmountConverter.FormatSats(lockedSats)</span> locked</span>
                        }
                        @if (Model.Balances.IncomingSats > 0)
                        {
                            <span class="text-secondary"><span class="fw-semibold">@SparkAmountConverter.FormatSats(Model.Balances.IncomingSats)</span> incoming</span>
                        }
                    </div>
                }
            </div>

            <div class="mt-3 pt-3 border-top d-flex gap-2 flex-wrap">
                <a asp-controller="Spark" asp-action="Send" asp-route-storeId="@Model.StoreId" class="btn btn-sm btn-primary">Send</a>
                <a asp-controller="Spark" asp-action="Receive" asp-route-storeId="@Model.StoreId" class="btn btn-sm btn-outline-primary">Receive</a>
                <a asp-controller="Spark" asp-action="History" asp-route-storeId="@Model.StoreId" class="btn btn-sm btn-outline-secondary">History</a>
            </div>

            @if (hasActivity)
            {
                <div class="mt-3 pt-3 border-top">
                    <div class="small text-secondary mb-2 d-flex justify-content-between align-items-center">
                        <span>Recent activity</span>
                        <a asp-controller="Spark" asp-action="History" asp-route-storeId="@Model.StoreId" class="text-secondary">All →</a>
                    </div>
                    @* Compact single-line variant of the canonical row layout — same arrow / kind /
                       amount / status as History, just packed tighter to fit the widget card. *@
                    <ul class="list-unstyled mb-0">
                        @foreach (var r in Model.RecentActivity)
                        {
                            var outgoing = r.Direction == BTCPayServer.Plugins.Spark.Models.SparkActivityDirection.Outgoing;
                            var incoming = r.Direction == BTCPayServer.Plugins.Spark.Models.SparkActivityDirection.Incoming;
                            <li class="d-flex justify-content-between align-items-center py-1 small">
                                <div class="text-truncate me-2 d-flex align-items-center gap-2">
                                    <span class="@SparkViewHelpers.DirectionClass(outgoing, incoming) fw-bold">@SparkViewHelpers.DirectionArrow(outgoing, incoming)</span>
                                    <span class="badge @r.KindBadgeClass">@r.Kind</span>
                                    <span class="fw-semibold">@SparkAmountConverter.FormatSats(r.AmountSats)</span>
                                    <span class="text-secondary">sats</span>
                                    <span class="badge @r.StatusBadgeClass" title="@(r.Error ?? r.StatusRaw)">@r.StatusLabel</span>
                                </div>
                                <small class="text-secondary flex-shrink-0" title="@r.At.UtcDateTime.ToString("u")">@SparkViewHelpers.RelativeTime(r.At)</small>
                            </li>
                        }
                    </ul>
                </div>
            }
        }
    </div>
</div>
